{
  "name": "@shopitt/auth-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node src/main.ts",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "dist/apps/auth-service",
          "format": [
            "esm"
          ],
          "bundle": true,
          "main": "apps/auth-service/src/main.ts",
          "tsConfig": "apps/auth-service/tsconfig.app.json",
          "external": [
            "@prisma/client",
            "@shopitt/prisma",
            "@shopitt/prisma-client"
          ],
          "assets": [
            {
              "input": "apps/auth-service/swagger",
              "glob": "swagger-auth.json",
              "output": "swagger"
            },
            {
              "input": "apps/auth-service/swagger",
              "glob": "swagger-webhooks.json",
              "output": "swagger"
            },
            {
              "input": "apps/auth-service/src/assets",
              "glob": "**/*",
              "output": "assets"
            }
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            },
            "banner": {
              "js": "import { createRequire } from 'module'; import { fileURLToPath } from 'url'; const require = createRequire(import.meta.url); const __filename = fileURLToPath(import.meta.url); const __dirname = path.dirname(__filename);"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "generateLockfile": true,
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/auth-service/dist/package.json",
          "{workspaceRoot}/apps/auth-service/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/auth-service/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@shopitt/auth-service:build",
          "runBuildTargetDependencies": false,
          "runtimeArgs": [
            "--inspect=9230",
            "--import",
            "tsx",
            "--import",
            "dotenv/config"
          ]
        },
        "configurations": {
          "development": {
            "buildTarget": "@shopitt/auth-service:build:development"
          },
          "production": {
            "buildTarget": "@shopitt/auth-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "docker:build": {
        "dependsOn": [
          "build",
          "prune"
        ]
      }
    }
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^7.0.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
