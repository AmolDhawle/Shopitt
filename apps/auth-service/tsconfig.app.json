{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "outDir": "../../dist/out-tsc/apps/auth-service",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "src/types/**/*.d.ts",
    "../../libs/middleware/src/**/*.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/tests",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/__mocks__/**"
  ],
  "references": [
    {
      "path": "../../libs/middleware/tsconfig.lib.json"
    },
    {
      "path": "../../libs/redis/tsconfig.lib.json"
    },
    {
      "path": "../../libs/prisma-client/tsconfig.lib.json"
    },
    {
      "path": "../../libs/error-handler/tsconfig.lib.json"
    }
  ]
}
