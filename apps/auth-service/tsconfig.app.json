{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "jest"],
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../libs/redis/tsconfig.lib.json"
    },
    {
      "path": "../../libs/prisma-client/tsconfig.lib.json"
    },
    {
      "path": "../../libs/error-handler/tsconfig.lib.json"
    }
  ]
}
