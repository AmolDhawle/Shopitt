{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "outDir": "../../dist/apps/auth-service",
    "rootDir": "src",
    "types": ["node", "express"],
    "tsBuildInfoFile": "../../dist/apps/auth-service/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.json", "src/**/*.d.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/tests",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/__mocks__/**"
  ],
  "references": [
    {
      "path": "../../libs/redis/tsconfig.lib.json"
    },
    {
      "path": "../../libs/middleware/tsconfig.lib.json"
    },
    {
      "path": "../../libs/prisma-client/tsconfig.lib.json"
    },
    {
      "path": "../../libs/error-handler/tsconfig.lib.json"
    }
  ]
}
