{
  "name": "@shopitt/prisma-client",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "options": {
          "outputPath": "dist/libs/prisma-client",
          "main": "libs/prisma-client/src/index.ts",
          "tsConfig": "libs/prisma-client/tsconfig.lib.json",
          "bundle": true,
          "format": [
            "cjs"
          ],
          "platform": "node",
          "thirdParty": false,
          "external": [
            "@prisma/client",
            "node:fs",
            "node:path",
            "node:events"
          ],
          "banner": {
            "js": "import { createRequire } from 'module'; const require = createRequire(import.meta.url);"
          }
        }
      }
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
