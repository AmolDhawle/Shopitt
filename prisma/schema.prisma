generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Images {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  file_id String
  url     String
  userId  String? @unique @db.ObjectId
  shopId  String? @unique @db.ObjectId
  users   Users?  @relation(fields: [userId], references: [id])
  shops   Shops?  @relation(fields: [shopId], references: [id])
}

model ProductImages {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  file_id String
  url     String

  productId String   @db.ObjectId
  product   Products @relation(fields: [productId], references: [id])
}

enum UserRole {
  USER
  ADMIN

}

model Users {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String        @unique
  password    String?
  role        UserRole @default(USER)
  isVerified  Boolean       @default(false)
  following   String[]
  avatar      Images?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  shopReviews ShopReviews[]
  orders      Orders[]
  addresses   Address[]
  orderGroups OrderGroups[]
}

model ShopReviews {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      Users    @relation(fields: [userId], references: [id])
  rating    Float
  reviews   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shopId    String?  @db.ObjectId
  shops     Shops?   @relation(fields: [shopId], references: [id])
}

model ShopFollowers {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String   @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  shops     Shops?   @relation(fields: [shopsId], references: [id])
  shopsId   String?  @db.ObjectId

  @@unique([shopId, userId])
}

model Shops {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  bio           String?
  category      String
  avatar        Images?
  coverBanner   String?
  address       String
  opening_hours String?
  website       String?
  socialLinks   Json[]
  ratings       Float           @default(0)
  reviews       ShopReviews[]
  followers     ShopFollowers[]
  sellerId      String          @unique @db.ObjectId
  sellers       Sellers         @relation(fields: [sellerId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  products      Products[]
  orders        Orders[]
}

model Sellers {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String   @unique
  phone_number  String
  country_code  String
  password      String?
  isVerified    Boolean  @default(false)
  paymentStatus String?  @default("not_started") // not_started | onboarding | pending | active | restricted
  stripeId      String?
  shop          Shops?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shopId        String?  @db.ObjectId
}

model RefreshToken {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  token       String      @unique
  subjectId   String      @db.ObjectId
  subjectType AuthSubject
  expiresAt   DateTime
  createdAt   DateTime    @default(now())

  @@index([subjectId, subjectType])
}

enum AuthSubject {
  USER
  SELLER
  ADMIN
}

model SiteConfig {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  categories    String[]
  subCategories Json
  logo          String?
  banner        String?
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model DiscountCode {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  publicName    String
  discountType  DiscountType
  discountValue Float

  discountCode String
  shopId       String @db.ObjectId

  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  usageLimit Int?
  usedCount  Int       @default(0)

  minimumOrderAmount    Int?
  maximumDiscountAmount Int?
  applicableProducts    String[] @db.ObjectId
  applicableCategories  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([discountCode, shopId])
}

enum ProductStatus {
  Active
  Pending
  Draft
}

model Products {
  id                   String          @id @default(auto()) @map("_id") @db.ObjectId
  title                String
  shortDescription     String
  tags                 String[]
  warranty             String
  slug                 String          @unique
  brand                String?
  category             String?
  subcategory          String?
  regularPrice         Int
  salePrice            Int
  ratings              Float           @default(0)
  ratingsCount         Int             @default(0)
  status               ProductStatus   @default(Active)
  stock                Int
  sizes                String[]
  colors               String[]
  discountCodes        String[]        @db.ObjectId
  totalSales           Int             @default(0)
  images               ProductImages[]
  videoUrl             String?
  customSpecifications Json?
  customProperties     Json
  cashOnDelivery       String
  detailedDescription  String
  isEvent              Boolean         @default(false)
  startingDate         DateTime?
  endingDate           DateTime?
  isDeleted            Boolean         @default(false)
  deletedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  shopId               String          @db.ObjectId
  shop                 Shops           @relation(fields: [shopId], references: [id])
  orderItems           OrderItems[]
}

model UserAnalytics {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique @db.ObjectId

  actions Json @default("[]")

  country         String?
  city            String?
  device          String?
  recommendations Json?

  lastVisited DateTime
  lastTrained DateTime? @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductAnalytics {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  productId String @unique @db.ObjectId
  shopId    String @db.ObjectId

  views        Int @default(0)
  cartAdds     Int @default(0)
  wishlistAdds Int @default(0)
  purchases    Int @default(0)

  lastViewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderTimelineStatus {
  ORDER_PLACED
  PAYMENT_CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERY_ATTEMPTED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURNED
  REFUND_INITIATED
  REFUNDED
}

model Orders {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderGroupId String?      @db.ObjectId
  orderGroup   OrderGroups? @relation(fields: [orderGroupId], references: [id])
  user     Users   @relation(fields: [userId], references: [id])
  userId    String  @db.ObjectId
  shop     Shops   @relation(fields: [shopId], references: [id])
  shopId    String  @db.ObjectId

  items OrderItems[]

  subtotal    Int
  discount    Int     @default(0)
  couponCode  String?
  tax         Int     @default(0)
  shippingFee Int     @default(0)
  total       Int

  orderStatus   OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)

  paymentMethod String?
  transactionId String?

  shippingAddressId String?  @db.ObjectId
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  placedAt DateTime @default(now())

  statusHistory OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([shopId])
  @@index([userId])
  
}

model OrderStatusHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String @db.ObjectId
  order   Orders @relation(fields: [orderId], references: [id])

  status OrderTimelineStatus
  note   String?

  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderItems {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String @db.ObjectId
  order   Orders @relation(fields: [orderId], references: [id])

  productId String   @db.ObjectId
  product   Products @relation(fields: [productId], references: [id])

  quantity Int
  price    Int // price at time of purchase
  size     String?
  color    String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model OrderGroups {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  users  Users  @relation(fields: [userId], references: [id])

  totalAmount   Int
  paymentStatus PaymentStatus
  paymentMethod String?
  transactionId String?

  orders Orders[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum addressType {
  Home
  Work
  Other
}

model Address {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   Users  @relation(fields: [userId], references: [id])

  label      addressType
  line1      String
  line2      String
  city       String
  postalCode String
  country    String

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Orders[]

  @@index([userId])
}

enum NotificationType {
  ORDER
  MESSAGE
  SYSTEM
  REVIEW
  PROMOTION
}

model Notifications {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title   String
  message String

  type NotificationType @default(SYSTEM)

  creatorId  String? @db.ObjectId
  receiverId String

  redirectLink String?

  entityId String? @db.ObjectId // orderId, productId, etc

  isRead Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([receiverId])
  @@index([creatorId])
  @@index([type])
}
